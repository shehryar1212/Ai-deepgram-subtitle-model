{
  "debug": false,
  "deepgram": {
    "api_key": "DEEPGRAM_API_KEY",
    "model": "nova-3",
    "language": "en",
    "sample_rate": 16000,
    "endpointing": 1000,
    "utterance_end_ms": 1500,
    "_utterance_end_ms_note": "wired — sent to Deepgram in _connect_kwargs",
    "dedup_window_seconds": 3.0,
    "buffer_max_words": 35,
    "buffer_timeout_seconds": 1.5,
    "keywords": ["OEE:3", "changeover:3", "scrap:3", "KPI:3", "downtime:3", "gym:3", "science:3", "Kyle:3", "Lucas:3", "math:2", "principal:2","first principles:2"]
  },
  "audio": {
    "mic_gain": 1.5,
    "_mic_gain_range": "valid range: 1.0-3.0",
    "blocksize": 4096,
    "channels": 1,
    "device": null
  },
  "openai": {
    "api_key": "OPENAI_API_KEY",
    "model": "gpt-4o-mini"
  },
  "languages": {
    "fr": "French",
    "it": "Italian",
    "pt": "Portuguese",
    "es": "Spanish",
    "el": "Greek",
    "bg": "Bulgarian",
    "sq": "Albanian"
  },
  "overlay": {
    "default_language": "fr",
    "font_size_current": 13,
    "font_size_previous": 11,
    "background_color": "#1a1a1a",
    "text_color_current": "#ffffff",
    "text_color_previous": "#888888",
    "divider_color": "#333333",
    "height": 120,
    "control_bar_height": 36
  },
  "audience": {
    "enabled": true,
    "language_code": "fr",
    "language_name": "French",
    "min_words": 2
  },
  "output": {
    "subtitle_file": "subtitle.txt",
    "partial_subtitle_file": "subtitle_partial.txt",
    "partial_min_word_delta": 3,
    "transcript_dir": "transcripts",
    "console_prefix": "[TRANSCRIPT]",
    "word_corrections": {
      "change over": "changeover",
      "Change over": "Changeover",
      "o e e": "OEE",
      "O E E": "OEE",
      "r and d": "R&D",
      "r & d": "R&D"
    }
  }
